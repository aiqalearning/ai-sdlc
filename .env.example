# Copy to .env and fill in. .env is git-ignored — never commit real values.

# --- Jira (Atlassian Cloud) ---
JIRA_URL=https://your-site.atlassian.net
JIRA_EMAIL=you@company.com
JIRA_TOKEN=your-atlassian-api-token

# --- GitHub (PR create/merge + GitHub MCP) ---
GITHUB_TOKEN=ghp_your_fine_grained_pat_with_repo_scope

# --- Jenkins (runs the Playwright automation) ---
JENKINS_URL=https://jenkins.company.com
JENKINS_USER=your-jenkins-user
JENKINS_TOKEN=your-jenkins-api-token
JENKINS_JOB=ai-sdlc-e2e

# --- Demo app (local verification) ---
DEMO_APP_PORT=3000
